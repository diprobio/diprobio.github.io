{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Diprobio project metadata",
  "type": "object",
  "required": ["organization", "projects"],
  "additionalProperties": true,
  "properties": {
    "organization": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "siteTitle": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "tags", "maintainers", "lastUpdated"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["active", "planning", "archived"]
          },
          "repo": {
            "type": "string",
            "format": "uri"
          },
          "repoName": {
            "type": "string",
            "minLength": 1
          },
          "docs": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "maintainers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "lastUpdated": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          }
        }
      }
    }
  }
}
